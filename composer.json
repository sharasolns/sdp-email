{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "sharasolns/sdp-email",
    "description": "An SDP Email API transport for Laravel Mail.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "email",
        "laravel",
        "sdp",
        "symfony-mailer"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/mail": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "symfony/http-client": "^7.0|^8.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Sdp\\Email\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sdp\\Email\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sdp\\Email\\SdpEmailServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
